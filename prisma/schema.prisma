  to_date                                   DateTime
  hours                                     Decimal
  status                                    task_assignments_status @default(Pending)
  notes                                     String?
  created_at                                DateTime @default(now()) 
  updated_at                                DateTime @default(now()) 
  users_task_assignments_assigned_toTousers users @relation("task_assignments_assigned_toTousers", fields: [assigned_to], references: [id], onDelete: Cascade, onUpdate: Restrict)
  users_task_assignments_assigned_byTousers users @relation("task_assignments_assigned_byTousers", fields: [assigned_by], references: [id], onDelete: Cascade, onUpdate: Restrict)
  projects                                  projects @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: Restrict)


  @@index([assigned_by])

  @@index([assigned_to])

  @@index([project_id])
}

