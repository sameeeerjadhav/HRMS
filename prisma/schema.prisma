generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model acl_requests {
  id          Int @id @default(autoincrement()) 
  user_id     Int
  work_date   DateTime
  reason      String
  hours       Decimal @default(9.00) 
  status      acl_requests_status @default(pending)
  reviewed_by Int?
  reviewed_at DateTime?
  review_note String?
  created_at  DateTime @default(now())
  @@index([work_date])

  @@index([status])

  @@index([user_id])
}

model app_settings {
  id            Int @id @default(autoincrement()) 
  setting_key   String @unique() 
  setting_value String?
  updated_at    DateTime @default(now()) 
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model attendance_locations {
  id              Int @id @default(autoincrement()) 
  name            String
  address         String?
  latitude        Decimal
  longitude       Decimal
  radius_m        Int @default(200) 
  is_remote       Boolean @default(false)
  is_active       Boolean @default(true)
  created_at      DateTime @default(now()) 
  attendance_logs attendance_logs[]
  user_locations  user_locations[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model attendance_logs {
  id                   Int @id @default(autoincrement()) 
  user_id              Int
  log_date             DateTime
  clock_in             DateTime?
  clock_out            DateTime?
  work_seconds         Int?
  ot_hours             Decimal @default(0.00) 
  status               attendance_logs_status @default(present)
  location_id          Int?
  clock_in_lat         Decimal?
  clock_in_lng         Decimal?
  clock_out_lat        Decimal?
  clock_out_lng        Decimal?
  note                 String?
  created_at           DateTime @default(now()) 
  updated_at           DateTime @default(now()) 
  attendance_locations attendance_locations? @relation(fields: [location_id], references: [id], onUpdate: Restrict)
  users                users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)


  @@unique([user_id, log_date])

  @@index([location_id])

  @@index([log_date])

  @@index([user_id])
}

model attendance_regularizations {
  id            Int @id @default(autoincrement()) 
  user_id       Int
  log_date      DateTime
  req_clock_in  DateTime
  req_clock_out DateTime
  reason        String
  status        attendance_regularizations_status @default(pending)
  reviewed_by   Int?
  reviewed_at   DateTime?
  review_note   String?
  escalated     Boolean @default(false)
  escalated_at  DateTime?
  created_at    DateTime @default(now()) 
  users         users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict)


  @@index([status])

  @@index([user_id])
}

